{
  "manifest_version": 3,
  "name": "다량 이미지 업로더",
  "version": "1.0.0",
  "description": "여러 개의 모양이 포함된 .eo 파일을 생성합니다.",
  "permissions": ["tabs", "downloads"],
  "action": {
    "default_title": "다량 이미지 업로더",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
