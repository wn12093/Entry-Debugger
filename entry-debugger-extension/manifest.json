{
  "manifest_version": 3,
  "name": "엔트리 디버깅 툴",
  "version": "1.0.6",
  "description": "엔트리(Entry) 코딩 플랫폼의 변수와 리스트를 실시간으로 모니터링하고 수정할 수 있는 디버깅 도구",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://playentry.org/ws/*",
        "http://localhost/ws/*",
        "http://127.0.0.1/ws/*"
      ],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": [
        "https://playentry.org/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ]
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
